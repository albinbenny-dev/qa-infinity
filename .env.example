# ════════════════════════════════════════════════════════════════════════════
# QA Infinity — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── App URL (sent to OpenRouter as HTTP-Referer) ─────────────────────────────
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:/data/qa-infinity.db

# ── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://qa-redis:6379

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Google SSO (optional — leave blank to disable the Google button) ──────────
# Step 1: https://console.cloud.google.com → APIs & Services → Credentials
# Step 2: Create OAuth 2.0 Client ID (type: Web application)
# Step 3: Add Authorized JavaScript Origins:
#           http://localhost:3000          ← local dev
#           https://your-production-domain ← production
# Step 4: Copy the Client ID below (the secret is NOT needed here)
GOOGLE_CLIENT_ID=

# Comma-separated email domains allowed to sign in via Google.
# Leave blank to allow any Google account (not recommended for production).
# Example: ALLOWED_DOMAINS=6dtech.co.in,airtelonline.com
ALLOWED_DOMAINS=

# ════════════════════════════════════════════════════════════════════════════
# AI / LLM PROVIDER  — choose ONE of the two options below
# Set LLM_PROVIDER to either "openrouter" or "anthropic"
# ════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=openrouter

# ── Option A: OpenRouter (recommended — works with your OpenRouter key) ───────
# Get your key at: https://openrouter.ai/keys
# Browse Claude models at: https://openrouter.ai/models?q=anthropic
OPENROUTER_API_KEY=
# Claude Sonnet 4 on OpenRouter — check https://openrouter.ai/models for exact name
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Option B: Direct Anthropic API ───────────────────────────────────────────
# Only needed if LLM_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Jira Integration (Writer Agent) ─────────────────────────────────────────
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Email / SMTP (Reports Agent) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=QA Infinity <no-reply@example.com>

# ── Docker runner ────────────────────────────────────────────────────────────
RUNNER_CONTAINER_NAME=qa-runner
PLAYWRIGHT_WORKERS=2

# ── File size limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800
