# ════════════════════════════════════════════════════════════════════════════
# QA Infinity — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── App URL (sent to OpenRouter as HTTP-Referer) ─────────────────────────────
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:/data/qa-infinity.db

# ── Redis / BullMQ ───────────────────────────────────────────────────────────
REDIS_URL=redis://qa-redis:6379

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: https://www.uuidgenerator.net/version4 (paste 2-3 UUIDs together)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ════════════════════════════════════════════════════════════════════════════
# AI / LLM PROVIDER  — choose ONE of the two options below
# Set LLM_PROVIDER to either "openrouter" or "anthropic"
# ════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=openrouter

# ── Option A: OpenRouter (recommended — works with your OpenRouter key) ───────
# Get your key at: https://openrouter.ai/keys
# Browse Claude models at: https://openrouter.ai/models?q=anthropic
OPENROUTER_API_KEY=
# Claude Sonnet 4 on OpenRouter — check https://openrouter.ai/models for exact name
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Option B: Direct Anthropic API ───────────────────────────────────────────
# Only needed if LLM_PROVIDER=anthropic
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Jira Integration (Writer Agent) ─────────────────────────────────────────
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# ── Email / SMTP (Reports Agent) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=QA Infinity <no-reply@example.com>

# ── Docker runner ────────────────────────────────────────────────────────────
RUNNER_CONTAINER_NAME=qa-runner
PLAYWRIGHT_WORKERS=2

# ── File size limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800
